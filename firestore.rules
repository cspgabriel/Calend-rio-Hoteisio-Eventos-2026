rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção de eventos (nome usado no código: 'eventos')
    // Leitura pública; escrita liberada pois não há Firebase Auth configurado.
    match /eventos/{eventId} {
      allow read: if true;
      allow write: if true;
    }

    // Coleção de feiras de turismo
    match /tourismFairs/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Nega acesso a qualquer outra coleção por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
